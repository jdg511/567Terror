        <mxCell id="p4title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;verticalAlign=middle;align=center;fontStyle=1;" value="PICO BRAIN detail v5 - slim panel edition: 2 footswitches, 4 mini buttons, ONE CD4051 mux, LFO1 uni / LFO2 bipolar fixed" vertex="1"><mxGeometry height="35" width="1650" x="40" y="920" as="geometry" /></mxCell>
        <mxCell id="p4pots" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=middle;align=center;" value="SINGLE CD4051 mux (U4) -&gt; ADC0:&#10;ch0 LFO1 RATE pot, ch1 LFO1 DEPTH pot,&#10;ch2 CV1 jack, ch3 CV2 jack (op-amp&#10;protected, scaled 0-3.3V),&#10;ch4-6 gate trims THRESH/HOLD/FADE,&#10;ch7 spare. (2nd mux deleted - LFO2 +&#10;OFFSET pots eliminated freed channels)" vertex="1"><mxGeometry height="130" width="240" x="40" y="980" as="geometry" /></mxCell>
        <mxCell id="p4foot" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;" value="FOOTSWITCHES x2 ONLY (v5):&#10;BYPASS (mechanical true bypass)&#10;+ TAP (LFO1) -&gt; GPIO:&#10;release &lt;800ms = tempo tap,&#10;hold &gt;1.3s = cycle waveform&#10;(1 step/450ms), 0.8-1.3s dead zone.&#10;LFO2 stomp DELETED" vertex="1"><mxGeometry height="120" width="240" x="40" y="1130" as="geometry" /></mxCell>
        <mxCell id="p4btn" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;" value="MINI BUTTONS x4 -&gt; GPIO:&#10;LFO2-1: tap=RATE, hold=WAVEFORM&#10;LFO2-2: tap=TARGET, hold=DEPTH&#10;CV1: tap=TARGET, hold=STRENGTH&#10;CV2: tap=TARGET, hold=STRENGTH&#10;Hold curve (log, LED = live preview):&#10;0%@1s, 1%@2s, 5%@3s, 50%@5s,&#10;100%@7s (capped)" vertex="1"><mxGeometry height="130" width="240" x="40" y="1270" as="geometry" /></mxCell>
        <mxCell id="p4pico" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;align=center;fontStyle=1;" value="RASPBERRY PI PICO (U3)&#10;module w/ castellated edges&#10;ADC0 = mux, ADC1 = env follower&#10;USB = drag-drop .uf2 updates&#10;FIRMWARE: 2x LFO (16 waveforms,&#10;LFO1 uni / LFO2 bipolar FIXED),&#10;tap tempo (LFO2 window ~20s),&#10;gate logic, mod matrix, hold-curve&#10;input, LED ctrl - mirrors sim v0.12" vertex="1"><mxGeometry height="180" width="240" x="360" y="1000" as="geometry" /></mxCell>
        <mxCell id="p4led" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;" value="WS2812D-F5 x4, ONE GPIO, chained:&#10;LFO1 -&gt; LFO2 -&gt; CV1 -&gt; CV2&#10;color = waveform/target (8 colors,&#10;Bank B blinks), brightness breathes&#10;w/ live LFO, previews depth during&#10;hold. 5V rail via series diode" vertex="1"><mxGeometry height="110" width="240" x="360" y="1210" as="geometry" /></mxCell>
        <mxCell id="p4pwm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;" value="PWM outputs + RC / Sallen-Key&#10;smoothing (6 mod CV channels):&#10;FREQ / FILTER / RES / GAIN /&#10;MIX / CV OUT&#10;(no DAC chip needed - PWM&#10;@ &gt;100kHz filters clean)" vertex="1"><mxGeometry height="140" width="240" x="660" y="1000" as="geometry" /></mxCell>
        <mxCell id="p4mode" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;" value="Mod elements at each knob:&#10;LED+LDR pairs on FREQ (567 RT),&#10;GAIN, MIX, RES / direct Iabc&#10;current into LM13700 for FILTER&#10;cutoff / gate LED direct PWM" vertex="1"><mxGeometry height="110" width="240" x="960" y="1000" as="geometry" /></mxCell>
