        <mxCell id="p4title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;verticalAlign=middle;align=center;fontStyle=1;" value="PICO BRAIN detail - Raspberry Pi Pico module (RP2040 / Pico 2, same footprint) - all LFO / gate / routing logic in firmware, audio stays analog" vertex="1"><mxGeometry height="35" width="1650" x="40" y="920" as="geometry" /></mxCell>
        <mxCell id="p4pots" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=middle;align=center;" value="Panel pots (6) + CV jacks (2)&#10;-&gt; CD4051 8-ch mux (U4) -&gt; ADC0&#10;ch0-5: LFO1 RATE/DEPTH/OFFSET,&#10;LFO2 RATE/DEPTH/OFFSET&#10;ch6-7: CV1 / CV2 (op-amp&#10;protected + scaled to 0-3.3V)" vertex="1"><mxGeometry height="120" width="230" x="40" y="980" as="geometry" /></mxCell>
        <mxCell id="p4foot" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;" value="TAP1 + TAP2 footswitches -&gt; GPIO&#10;release &lt;800ms = tempo tap&#10;hold &gt;1.3s = cycle waveform&#10;(1 step / 450ms while held)&#10;800ms-1.3s = dead zone" vertex="1"><mxGeometry height="100" width="230" x="40" y="1130" as="geometry" /></mxCell>
        <mxCell id="p4btn" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;" value="CV1 / CV2 TARGET buttons&#10;-&gt; GPIO (press = cycle target:&#10;Freq / Filter / Res / Gain / Mix&#10;+ CV2 extras: LFO1 Rate/Depth)" vertex="1"><mxGeometry height="90" width="230" x="40" y="1260" as="geometry" /></mxCell>
        <mxCell id="p4pico" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=middle;align=center;fontStyle=1;" value="RASPBERRY PI PICO (U3)&#10;module w/ castellated edges&#10;ADC0 = mux, ADC1 = env follower&#10;USB = drag-drop .uf2 updates&#10;FIRMWARE: 2x LFO (16 waveforms),&#10;tap tempo, gate logic, mod matrix&#10;(targets/strength/slew), LED ctrl&#10;- mirrors JUCE sim v0.11 1:1" vertex="1"><mxGeometry height="170" width="240" x="360" y="1000" as="geometry" /></mxCell>
        <mxCell id="p4led" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;verticalAlign=middle;align=center;" value="WS2812D-F5 x4, ONE GPIO, chained:&#10;LFO1 -&gt; LFO2 -&gt; CV1 -&gt; CV2&#10;color = waveform / target,&#10;brightness breathes w/ live LFO&#10;5V rail via series diode (~4.3V)" vertex="1"><mxGeometry height="100" width="240" x="360" y="1200" as="geometry" /></mxCell>
        <mxCell id="p4pwm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;" value="PWM outputs + RC / Sallen-Key&#10;smoothing (6 mod CV channels):&#10;FREQ / FILTER / RES / GAIN /&#10;MIX / CV OUT&#10;(no DAC chip needed - PWM&#10;@ &gt;100kHz filters clean,&#10;STOMPLFO-PDM style)" vertex="1"><mxGeometry height="150" width="240" x="660" y="1000" as="geometry" /></mxCell>
        <mxCell id="p4mode" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=middle;align=center;" value="Mod elements at each knob:&#10;LED+LDR pairs on FREQ (567 RT),&#10;GAIN, MIX, RES / direct Iabc&#10;current into LM13700 for FILTER&#10;cutoff / gate LED direct PWM" vertex="1"><mxGeometry height="110" width="240" x="960" y="1000" as="geometry" /></mxCell>
        <mxCell id="p4pwr" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;verticalAlign=middle;align=center;fontStyle=1;" value="+5V Reg (78L05) from 9V rail:&#10;Pico VSYS + WS2812 (via diode)&#10;Pico 3V3-out -&gt; pot/mux reference" vertex="1"><mxGeometry height="70" width="260" x="960" y="1160" as="geometry" /></mxCell>
