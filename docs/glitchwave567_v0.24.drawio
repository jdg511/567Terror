0" width="240" height="150" as="geometry"/></mxCell><mxCell id="dirt" value="BAZZ FUSS dirt&lt;br&gt;always on, DRY only&lt;br&gt;GAIN x1.1..x300 - starve sputter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="480" y="170" width="190" height="70" as="geometry"/></mxCell><mxCell id="mix" value="inverting mixer&lt;br&gt;U1.2  (MIX - VOL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1110" y="95" width="120" height="60" as="geometry"/></mxCell><mxCell id="svf" value="envelope filter SVF&lt;br&gt;LP/BP/HP/Notch&lt;br&gt;RES - range Lo/Hi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1270" y="90" width="150" height="70" as="geometry"/></mxCell><mxCell id="odcb" value="output DC block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1270" y="300" width="130" height="50" as="geometry"/></mxCell><mxCell id="hp60" value="60 Hz HP&lt;br&gt;12 dB/oct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1110" y="300" width="120" height="50" as="geometry"/></mxCell><mxCell id="pk8" value="+3 dB bell&lt;br&gt;@ 800 Hz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="950" y="300" width="120" height="50" as="geometry"/></mxCell><mxCell id="boost" value="+6 dB BOOST&lt;br&gt;button ON/OFF&lt;br&gt;(2nd-to-last)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf6df;strokeColor=#b98a00;fontColor=#21242a;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="770" y="295" width="140" height="60" as="geometry"/></mxCell><mxCell id="clip" value="CLIP STAGE (last)&lt;br&gt;A -6 / B -9 / D JFET / D+B&lt;br&gt;E -9/rail  F -9/-3&lt;br&gt;G -6/rail  H -3/rail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fbe3e2;strokeColor=#e34948;fontColor=#21242a;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="290" width="170" height="80" as="geometry"/></mxCell><mxCell id="gate" value="OUTPUT GATE&lt;br&gt;thresh - hold - fade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="380" y="300" width="140" height="60" as="geometry"/></mxCell><mxCell id="out" value="OUT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f4ec;strokeColor=#1baf7a;fontColor=#21242a;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="280" y="310" width="60" height="40" as="geometry"/></mxCell><mxCell id="pwr" value="POWER&lt;br&gt;9-18 V centre-negative - P-FET reverse protect&lt;br&gt;RC + ferrite filtering&lt;br&gt;STARVE sags analog rail to 5 V floor (secret)&lt;br&gt;LM567 + Pico on their own regulators" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f4ec;strokeColor=#1baf7a;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="30" y="440" width="330" height="120" as="geometry"/></mxCell><mxCell id="modsys" value="MOD SYSTEM (Pico)&lt;br&gt;LFO1: 16 shapes (Bank A+B) - 0.2-20 Hz - depth - 8 targets&lt;br&gt;LFO2: same shapes - 0.2-20 Hz - depth - 8 targets (incl. LFO1 rate/depth)&lt;br&gt;ENV follower: gain - drive up/dn - 8 targets&lt;br&gt;CV1 jack = LFO1 depth VCA - CV2 jack = LFO2 depth VCA&lt;br&gt;tap x4 tempo (TAP=LFO1, BYPASS+TAP=LFO2) re-seeds chaos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe9fb;strokeColor=#2a78d6;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="480" y="430" width="590" height="170" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.240" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="in" target="dcb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.241" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="dcb" target="buf"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.242" value="wet" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="buf" target="trim"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.243" value="dry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="buf" target="dirt"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.244" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="trim" target="gain"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.245" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="gain" target="pll"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.246" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="pll" target="mix"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.247" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="dirt" target="mix"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="eSignal Flow v0.248" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#21242a;strokeWidth=1.6;" edge="1" parent="1" source="mix" target="svf"><mxGeometr