x="915" y="136" width="135" height="40" as="geometry"/></mxCell><mxCell id="c30" value="LFO1 Depth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="190" y="186" width="135" height="40" as="geometry"/></mxCell><mxCell id="c31" value="LFO2 Depth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="335" y="186" width="135" height="40" as="geometry"/></mxCell><mxCell id="c32" value="DRV/RNG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="480" y="186" width="135" height="40" as="geometry"/></mxCell><mxCell id="c33" value="Shape A&amp;B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="625" y="186" width="135" height="40" as="geometry"/></mxCell><mxCell id="c34" value="Shape A&amp;B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="770" y="186" width="135" height="40" as="geometry"/></mxCell><mxCell id="c35" value="Mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=10;" vertex="1" parent="1"><mxGeometry x="915" y="186" width="135" height="40" as="geometry"/></mxCell><mxCell id="r1" value="C1&lt;br&gt;nothing held" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="86" width="150" height="40" as="geometry"/></mxCell><mxCell id="r2" value="C2&lt;br&gt;hold TAP (sim CTRL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbe9fb;strokeColor=#2a78d6;fontColor=#21242a;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="136" width="150" height="40" as="geometry"/></mxCell><mxCell id="r3" value="C3&lt;br&gt;hold BYPASS (sim ALT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeadd;strokeColor=#eb6834;fontColor=#21242a;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="186" width="150" height="40" as="geometry"/></mxCell><mxCell id="starve" value="BOTH stomps held (secret / easter egg, unlabeled on the pedal): MIX knob = STARVE (rail sags to 5 V floor) - every other knob goes DEAD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fbe3e2;strokeColor=#e34948;fontColor=#21242a;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="246" width="1015" height="40" as="geometry"/></mxCell><mxCell id="tap" value="TAP STOMP&lt;br&gt;tap x4 = LFO1 RATE (avg of last 4 taps)&lt;br&gt;with BYPASS held: sets LFO2 RATE&lt;br&gt;1-3 taps arm only - rolling window&lt;br&gt;range 0.2-20 Hz (same as knobs)&lt;br&gt;committed tap re-seeds that LFO's chaos&lt;br&gt;HOLD = C2 layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=9;" vertex="1" parent="1"><mxGeometry x="20" y="316" width="330" height="130" as="geometry"/></mxCell><mxCell id="byp" value="BYPASS STOMP&lt;br&gt;tap = bypass on/off (buffered, 10 ms fade)&lt;br&gt;HOLD = C3 layer&lt;br&gt;BOTH stomps = STARVE (secret)&lt;br&gt;turning any knob during a hold&lt;br&gt;cancels that stomp's tap/toggle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f2f4;strokeColor=#9aa0a6;fontColor=#21242a;fontSize=9;" vertex="1" parent="1"><mxGeometry x="380" y="316" width="330" height="130" as="geometry"/></mxCell><mxCell id="led" value="SECTION LEDs (one per section)&lt;br&gt;idle: WHITE breathes LFO wave / env level&lt;br&gt;C2: TARGET = solid hue (Off = dim)&lt;br&gt;C3: SHAPE hue - Bank A blinks 2 Hz, B 5 Hz&lt;br&gt;DEPTH = BLUE at depth %&lt;br&gt;MODE = hue blinks 3 Hz&lt;br&gt;DRV/RNG = hue SOLID (no blink)&lt;br&gt;colours update LIVE while the knob turns" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eae7f7;strokeColor=#4a3aa7;fontColor=#21242a;fontSize=9;" vertex="1" parent="1"><mxGeometry x="740" y="316" width="295" height="190" as="geometry"/></mxCell><mxCell id="btns" value="AUDITION BUTTONS (sim only - winners get hardwired)&lt;br&gt;+6 dB: ON/OFF   -   CLIP: A -6 sym | B -9 sym | D JFET | D+B | E -9/rail | F -9/-3 | G -6/rail | H -3/rail   -   SUPPLY: 9 V / 18 V" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf6df;strokeColor=#b98a00;fontColor=#21242a;fontSize=9;" vertex="1" parent="1"><mxGeometry x="20" y="476" width="690" height="70" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
